# ─── HY3N Backend — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values before running locally
# (npm run dev / npm start). Do NOT set PORT here — it's a reserved name on
# both Cloud Run and Firebase Functions and defining it yourself breaks their
# env loading; src/index.ts already defaults to 3000 when it's unset.
#
# For an actual Firebase Functions deployment, everything below except
# NODE_ENV is set via `firebase functions:secrets:set <NAME>` instead of this
# file — see src/functions.ts's `secrets` list and the README.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Optional locally (paste the service account JSON as a string). When deployed
# as a Firebase Function, leave this unset — the function's own runtime
# service account already has Firestore access in the same project, no
# separate credential needed.
FIREBASE_SERVICE_ACCOUNT=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=HY3N Transport <noreply@ridehy3n.com>

# ── Hubtel Mobile Money ───────────────────────────────────────────────────────
HUBTEL_API_ID=
HUBTEL_API_KEY=
HUBTEL_POS_NUMBER=

# ── Admin Dashboard ───────────────────────────────────────────────────────────
# Required — no default. Visiting /admin/commission POSTs here to unlock the UI.
ADMIN_DASHBOARD_PIN=

# ── Public Payments API (Basic Auth for external mobile app clients) ─────────
PUBLIC_PAYMENTS_API_USERNAME=
PUBLIC_PAYMENTS_API_PASSWORD=

# ── Google Maps (Places autocomplete/details proxy) ───────────────────────────
GOOGLE_MAPS_API_KEY=

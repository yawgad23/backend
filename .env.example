# ─── HY3N Backend — Environment Variables ────────────────────────────────────
# Copy this file to .env.local (NOT .env!) and fill in your values before
# running locally (npm run dev / npm start / firebase emulators:start).
#
# Firebase Functions deploys the plain contents of a bare `.env` file as real
# production environment variables — it is NOT local-only. `.env.local` is
# the Firebase-specific convention for values that should exist only for
# local dev/emulator runs and never get uploaded on `firebase deploy`.
#
# Do NOT set PORT here — it's a reserved name on both Cloud Run and Firebase
# Functions; src/index.ts already defaults to 3000 when it's unset.
#
# Everything below except NODE_ENV is a real secret in production, set via
# `firebase functions:secrets:set <NAME>` instead of any .env file — see
# src/functions.ts's `secrets` list and the README. If a name here is ever
# also set as a secret, it must NOT also appear in a deployed `.env` (only
# `.env.local`) — Firebase refuses to deploy when the same name is both a
# plain env var and a secret.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Optional locally (paste the service account JSON as a string). When deployed
# as a Firebase Function, leave this unset — the function's own runtime
# service account already has Firestore access in the same project, no
# separate credential needed.
FIREBASE_SERVICE_ACCOUNT=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=HY3N Transport <noreply@ridehy3n.com>

# ── Hubtel Mobile Money ───────────────────────────────────────────────────────
HUBTEL_API_ID=
HUBTEL_API_KEY=
HUBTEL_POS_NUMBER=

# ── Admin Dashboard ───────────────────────────────────────────────────────────
# Required — no default. Visiting /admin/commission POSTs here to unlock the UI.
ADMIN_DASHBOARD_PIN=

# ── Public Payments API (Basic Auth for external mobile app clients) ─────────
PUBLIC_PAYMENTS_API_USERNAME=
PUBLIC_PAYMENTS_API_PASSWORD=

# ── Google Maps (Places autocomplete/details proxy) ───────────────────────────
GOOGLE_MAPS_API_KEY=

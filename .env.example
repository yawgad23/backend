# ─── HY3N Backend — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values before running locally.
# In Cloud Run, these are set via --set-env-vars (config) / --set-secrets (secrets).

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Optional locally (paste the service account JSON as a string). On Cloud Run,
# leave this unset and instead grant the runtime service account the
# "Cloud Datastore User" IAM role — Application Default Credentials picks it
# up automatically.
FIREBASE_SERVICE_ACCOUNT=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=HY3N Transport <noreply@ridehy3n.com>

# ── Hubtel Mobile Money ───────────────────────────────────────────────────────
HUBTEL_API_ID=
HUBTEL_API_KEY=
HUBTEL_POS_NUMBER=

# ── Admin Dashboard ───────────────────────────────────────────────────────────
# Required — no default. Visiting /admin/commission POSTs here to unlock the UI.
ADMIN_DASHBOARD_PIN=

# ── Public Payments API (Basic Auth for external mobile app clients) ─────────
PUBLIC_PAYMENTS_API_USERNAME=
PUBLIC_PAYMENTS_API_PASSWORD=

# ── Google Maps (Places autocomplete/details proxy) ───────────────────────────
GOOGLE_MAPS_API_KEY=
